# IOT System — ignore local secrets, dependencies, and generated files.
# Keep this list updated when tooling or paths change.

# Secrets — never commit
.env
**/.env
.env*.local
**/.env.*.local

# Dependencies
node_modules/
water-leak-monitor/node_modules/
water-leak-monitor/firmware/bridge/node_modules/

# Expo
.expo/
water-leak-monitor/.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*
**/.metro-health-check*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS / Windows
.DS_Store
Thumbs.db
*.pem

# Editor / IDE (local only)
.cursor/
.vscode/

# TypeScript
*.tsbuildinfo

# Generated native folders
/ios
/android

# Supabase CLI local state (optional)
.supabase/
supabase/.temp/

# JVM / crash logs
hs_err_pid*.log
replay_pid*.log
*.log
