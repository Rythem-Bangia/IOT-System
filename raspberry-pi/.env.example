# Copy to .env and fill in, or use export in your shell.
# macOS: use python3, not python.

# --- Option A: same login as Expo app ---
# SUPABASE_EMAIL=
# SUPABASE_PASSWORD=

# --- Option B: device gateway (no password) ---
# ZONE_ID=uuid-from-supabase-zones-table
# DEVICE_SECRET=uuid-from-devices-table
# DEFAULT_MOISTURE_THRESHOLD=65

# Optional overrides (defaults match repo .env)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# SENSOR_DRIVER=mock
# POLL_INTERVAL_S=5
